LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_THROTTLE_RATE=10/min
ACCESS_TOKEN_LIFETIME_MIN=30
REFRESH_TOKEN_LIFETIME_DAYS=7
